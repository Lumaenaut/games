{
  "manifest_version": 3,
  "name": "Second Runner",
  "version": "1.0.0",
  "description": "Mini-games and timer-based running companion",
  
  "action": {
    "default_popup": "src/popup/greeting.html",
    "default_title": "Second Runner",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "permissions": [
    "storage"
  ],
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}