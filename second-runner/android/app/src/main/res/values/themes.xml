<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SecondRunner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dark</item>
        <item name="colorPrimaryVariant">@color/darkest</item>
        <item name="colorOnPrimary">@color/lightest</item>
        <item name="android:windowBackground">@color/darkest</item>
        <item name="android:statusBarColor">@color/darkest</item>
        <item name="android:navigationBarColor">@color/darkest</item>
    </style>
    <style name="Widget.SecondRunner.GameButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_game_button_chunky</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/darkest</item>
        <item name="android:padding">20dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>