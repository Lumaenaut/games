<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/darkest"
    android:clickable="true"
    android:focusable="true"
    tools:context=".WelcomeFragment">

    <com.lumaenaut.secondrunner.GreetingBackgroundView
        android:id="@+id/greetingBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textColor="@color/lightest"
            android:textSize="56sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:fontFamily="monospace"
            android:shadowColor="@color/darkest"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/clickToStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/click_to_start"
            android:textColor="@color/lightest"
            android:textSize="14sp"
            android:letterSpacing="0.18"
            android:fontFamily="monospace" />
    </LinearLayout>
</FrameLayout>
