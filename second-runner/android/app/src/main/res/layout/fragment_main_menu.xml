<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/darkest"
    android:padding="16dp"
    tools:context=".MainMenuFragment">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp"
        android:text="@string/app_name"
        android:textColor="@color/lightest"
        android:textSize="48sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:fontFamily="monospace"
        android:shadowColor="@color/darkest"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:baselineAligned="false">

        <Button
            android:id="@+id/buttonHandball"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_game_button_chunky"
            android:text="@string/handball"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            style="@style/Widget.SecondRunner.GameButton" />

        <Button
            android:id="@+id/buttonHockey"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_game_button_chunky"
            android:text="@string/hockey"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            style="@style/Widget.SecondRunner.GameButton" />

        <Button
            android:id="@+id/buttonTennis"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_game_button_chunky"
            android:text="@string/tennis"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            style="@style/Widget.SecondRunner.GameButton" />
    </LinearLayout>
</LinearLayout>
