<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape: left column (scores + back, same width), right column (court + instructions). -->
<com.lumaenaut.secondrunner.GameScreenRootLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/gameScreenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/darkest"
    android:orientation="vertical"
    tools:context=".GameFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Left column: scores and back button, aligned right, same-width score boxes -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="end"
            android:minWidth="120dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/playerScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_score_box"
                android:fontFamily="monospace"
                android:gravity="end"
                android:letterSpacing="0.08"
                android:minWidth="160dp"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp"
                android:textAllCaps="true"
                android:textColor="@color/darkest"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="PLAYER: 0" />

            <TextView
                android:id="@+id/computerScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_score_box"
                android:fontFamily="monospace"
                android:gravity="end"
                android:letterSpacing="0.08"
                android:minWidth="160dp"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp"
                android:textAllCaps="true"
                android:textColor="@color/darkest"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="COMPUTER: 0" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/backButton"
                style="@style/Widget.SecondRunner.GameButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:padding="8dp"
                android:text="@string/back_to_menu"
                android:textAllCaps="true"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Center: court and instructions (same width so text is centered under court) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/gameContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:padding="12dp"
                android:textColor="@color/light"
                android:textSize="14sp"
                tools:text="MOVE FINGER UP/DOWN TO CONTROL THE PADDLE" />
        </LinearLayout>
    </LinearLayout>
</com.lumaenaut.secondrunner.GameScreenRootLayout>
